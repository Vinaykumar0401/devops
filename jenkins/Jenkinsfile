pipeline {

    agent { label 'java-node' }

    tools {
        jdk 'JDK17'
        maven 'maven'
    }

    options {
        buildDiscarder(logRotator(
            numToKeepStr: '3',
            artifactNumToKeepStr: '3'
        ))
        disableConcurrentBuilds()
        timestamps()
    }

    environment {
        IMAGE_NAME = "spring-petclinic"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/spring-projects/spring-petclinic.git'
            }
        }


        stage('Build') {
            steps {
                sh 'java -version'
                sh 'mvn -version'
                sh 'mvn clean compile'
            }
        }


        stage('Start Test Database') {
            steps {
                sh '''
                    echo "Starting PostgreSQL container for tests"

                    docker rm -f petclinic-postgres || true

                    docker run -d \
                    --name petclinic-postgres \
                    -e POSTGRES_DB=petclinic \
                    -e POSTGRES_USER=petclinic \
                    -e POSTGRES_PASSWORD=petclinic \
                    -p 5433:5432 \
                    postgres:18.4

                    echo "Waiting for PostgreSQL startup"
                    sleep 15

                    docker ps
                '''
            }
        }


        stage('Test') {
            steps {
                sh '''
                    mvn test \
                    -Dspring.docker.compose.skip-in-tests=true \
                    -Dspring.profiles.active=postgres
                '''
            }

            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }


        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=spring-petclinic \
                        -Dsonar.projectName=spring-petclinic
                    '''
                }
            }
        }


        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }


        stage('Package') {
            steps {
                sh 'mvn package -DskipTests'
            }
        }


        stage('Docker Build') {
            steps {
                sh '''
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .

                    docker images | grep ${IMAGE_NAME}
                '''
            }
        }


        stage('Deploy') {
            steps {
                echo "Deployment Successful"
            }
        }
    }


    post {

        success {
            echo "Pipeline completed successfully."
        }


        failure {
            echo "Pipeline failed."
        }


        always {
            sh '''
                echo "Cleaning test PostgreSQL container"

                docker rm -f petclinic-postgres || true
            '''

            cleanWs()
        }
    }
}
