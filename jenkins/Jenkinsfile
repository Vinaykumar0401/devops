pipeline {
    agent { label 'java-node' }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/spring-projects/spring-petclinic.git'
            }
        }

        stage('Build') {
            tools {
                jdk 'JDK17'
                maven 'maven'
            }

            steps {
                sh 'pwd'
                sh 'ls -la'
                sh 'java -version'
                sh 'mvn -version'
                sh 'mvn package'
            }
        }

        stage('Test') {
            tools {
                jdk 'JDK17'
                maven 'maven'
            }

            steps {
                sh 'java -version'
                // sh 'mvn test'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploy stage'
            }
        }
    }
}
