pipeline {
    agent any
    tools {
        jdk 'JDK17'
        maven 'maven'
    }
    stages {
        stage("mvnBuild") {
            agent { label 'java-agent-slave' }
            steps {
            sh 'java -version'
            sh 'mvn -version'
            sh 'mvn clean package'
        }
        }
        stage("Test") {
            agent { label 'java-agent-slave' }
            steps {
                echo 'Testing...'
            }
        }
        stage("Deploy") {
            steps {
                echo 'Deploying...'
            }
        }
    }
}
