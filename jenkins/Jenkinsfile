pipeline {
    agent { label 'java-node' }

    options {
        buildDiscarder(logRotator(numToKeepStr: '3', artifactNumToKeepStr: '3'))
    }

    tools {
        jdk 'JDK17'
        maven 'maven'
    }

    environment {
        IMAGE_NAME = "vinay1504/spring-petclinic"
        IMAGE_TAG = "${BUILD_NUMBER}"
        LATEST_TAG = "latest"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Vinaykumar0401/spring-petclinic-devops.git'
            }
        }

        stage('Fix Docker Compose') {
            steps {
                sh '''
                if [ -f docker-compose.yml ]; then
                    sed -i 's/"5432:5432"/"5433:5432"/g' docker-compose.yml
                fi
                '''
            }
        }

        stage('Build & Test') {
            steps {
                sh 'mvn -Dmaven.repo.local=.m2 clean verify'
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    mvn -Dmaven.repo.local=.m2 sonar:sonar \
                    -Dsonar.projectKey=petclinic \
                    -Dsonar.projectName=petclinic
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Deploy Artifact to Nexus') {
            steps {
                sh 'mvn -Dmaven.repo.local=.m2 deploy -DskipTests'
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:${LATEST_TAG}
                """
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh """
                docker push ${IMAGE_NAME}:${IMAGE_TAG}
                docker push ${IMAGE_NAME}:${LATEST_TAG}
                """
            }
        }

        stage('Deploy Application') {
            steps {
                sh """
                docker rm -f petclinic || true

                docker pull ${IMAGE_NAME}:${LATEST_TAG}

                docker run -d \
                    --name petclinic \
                    -p 8080:8080 \
                    --restart unless-stopped \
                    ${IMAGE_NAME}:${LATEST_TAG}
                """
            }
        }

    }

    post {

        success {
            echo "Pipeline completed successfully."
        }

        failure {
            echo "Pipeline failed."
        }

        always {
            cleanWs()
        }
    }
}